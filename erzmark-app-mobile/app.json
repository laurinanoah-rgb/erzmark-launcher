{
  "expo": {
    "name": "Erzmark",
    "slug": "erzmark-app",
    "version": "0.1.0",
    "scheme": "erzmark",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0e0f12",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/eb463b79-7bd4-4e3c-846b-491c27d4d8a3"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.erzmark.app"
    },
    "android": {
      "package": "de.erzmark.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0f12"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Erzmark braucht Zugriff auf deine Fotos, um ein Titelbild oder Logo für deine Gilde hochzuladen."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "eb463b79-7bd4-4e3c-846b-491c27d4d8a3"
      }
    }
  }
}
