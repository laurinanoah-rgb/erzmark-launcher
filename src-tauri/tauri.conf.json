{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Erzmark Launcher",
  "version": "1.4.3",
  "identifier": "de.erzmark.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Erzmark Launcher",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "maximized": true,
        "center": true,
        "decorations": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost https://textures.minecraft.net https://erzmark.de data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; media-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Erzmark",
    "category": "Game",
    "shortDescription": "Launcher für den Erzmark Minecraft-Server",
    "longDescription": "Offizieller Desktop-Launcher für das Erzmark Minecraft-RPG-Serverprojekt.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "licenseFile": "installer/EULA.txt",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyMjczQzYxQ0MxQjQwRjAKUldUd1FCdk1ZVHduWWpSY0pRVEl5ZVZHeTNTMUUrWXJveFdpTjF2dHYzT1NiQWp2d2l4ck8rTUkK",
      "endpoints": ["https://erzmark.de/launcher/updates/latest.json"]
    }
  }
}
